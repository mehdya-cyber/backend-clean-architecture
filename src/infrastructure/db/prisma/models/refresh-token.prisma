model RefreshToken {
    id         String  @id @default(cuid())
    userId     String
    familyId   String
    tokenHash  String  @unique
    replacedBy String?
    userAgent  String?
    ipAddress  String?

    revokedAt DateTime?
    expiresAt DateTime
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
}
